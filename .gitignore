# but ignore any local copies just in case)
*.json.bak
user-data/
app-data/
data/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.suo
*.user

# Logs
*.log
npm-debug.log*

# TypeScript cache
*.tsbuildinfo

# Device-specific launchers (contain hardcoded local paths)
launch.bat
launch.vbs
