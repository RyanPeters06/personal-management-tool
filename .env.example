# ── Client-side (safe to expose — protected by Supabase Row Level Security) ──
# Supabase project URL and anon/public key (Settings → API in the Supabase dashboard)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: base URL of the deployed app, used by local dev / Electron to reach
# the /api/anthropic proxy (e.g. https://life-manager.vercel.app). Leave empty
# when the app is served from the same origin as the proxy (i.e. on Vercel).
VITE_API_BASE=

# ── Server-side only (NEVER prefixed with VITE_, never shipped to the client) ──
# Set this in Vercel → Project → Settings → Environment Variables
ANTHROPIC_API_KEY=
